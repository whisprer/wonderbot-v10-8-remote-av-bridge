# Copy to .env and adjust for your server.

# Host paths
WONDERBOT_WEIGHTS_ROOT=/srv/weights/wonderbot
WONDERBOT_PROFILE=/app/configs/profiles/dual-p40-server-qwen14b.toml
WONDERBOT_STATE_ROOT=/srv/weights/wonderbot/state
WONDERBOT_OFFLOAD_ROOT=/srv/weights/wonderbot/offload
WONDERBOT_HF_CACHE=/srv/weights/wonderbot/hf-cache
WONDERBOT_WORKSPACE=/srv/weights/wonderbot/workspace

# GPU selection
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Optional Hugging Face auth for gated/private models
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=

# Optional OpenAI voice/API use
OPENAI_API_KEY=

# Extra startup flags appended to wonderbot command
WONDERBOT_EXTRA_ARGS=--diagnostics
